{
  "name": "dpp-assessment-platform",
  "private": true,
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @dpp/web run dev",
    "dev:api": "npm --workspace @dpp/api run start:dev",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces"
  }
}
