# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dpp_assessment

# ── API server ────────────────────────────────────────────────────────────────
API_PORT=3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api

# ── Auth ──────────────────────────────────────────────────────────────────────
# Supported: entra-id
AUTH_PROVIDER=entra-id

# ── Jira ──────────────────────────────────────────────────────────────────────
# Cloud: https://your-domain.atlassian.net
# Server/Data Centre: https://jira.your-company.com
JIRA_BASE_URL=https://your-domain.atlassian.net

# Default project key used when creating new issues (e.g. WAR, DPP, PRIV)
JIRA_PROJECT_KEY=DPP

# Issue type for newly created assessment tickets
JIRA_ISSUE_TYPE=Task

# Service account email (Jira Cloud) or username (Server/DC)
JIRA_USERNAME=service-account@example.com

# Jira API token — generate at https://id.atlassian.com/manage-profile/security/api-tokens
# For Server/DC this is the user's password or a personal access token
JIRA_API_TOKEN=replace-me
